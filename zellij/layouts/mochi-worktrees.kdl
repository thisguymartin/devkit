layout {
    // Status bar at the bottom of every tab
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }

    // Tab 1: Worktree Overview
    // This layout is designed to be generated dynamically by Mochi (--workspace zellij).
    // When launched manually, it shows a single pane with instructions.
    tab name="Worktrees" {
        pane split_direction="vertical" {
            // Left: Git views (lazygit per worktree)
            pane split_direction="horizontal" size="40%" {
                pane command="lazygit" name="Git: Worktree 1"
            }

            // Right: Shell per worktree
            pane split_direction="horizontal" size="60%" {
                pane name="Shell: Worktree 1" {
                    focus true
                }
            }
        }
    }

    // Tab 2: Manifest watcher — live status of all Mochi worktrees
    tab name="Manifest" {
        pane command="watch" name="Mochi Status" {
            args "-n" "2" "cat" ".mochi_manifest.json"
        }
    }

    // Tab 3: AI Agent (optional — for running ad-hoc commands)
    tab name="Agent" {
        pane command="$AI_EDITOR" name="AI Agent"
    }
}
